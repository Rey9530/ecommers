# ------------------------------------------------------------------------------
# .env.example — Variables opcionales para docker-compose.yaml
# Copia este archivo a `.env` en el servidor (al lado de docker-compose.yaml)
# y rellena los valores que quieras cambiar. Las líneas vacías o comentadas
# usan los defaults indicados en docker-compose.yaml.
# ------------------------------------------------------------------------------

# Puerto del host mapeado al puerto 3000 del contenedor.
# Si en el host ya hay otro servicio en :3000, mapea a otro puerto: 8080:3000.
PORT=3000

# Tag de la imagen reyles/ecommerce a descargar desde Docker Hub.
# Default: latest (lo que se actualiza en cada push a main).
# Para producción pinneada, fija una versión específica:
#   IMAGE_TAG=sha-aa8219a       # recomendado: apunta a un commit concreto
#   IMAGE_TAG=main              # o usa la rama main si la workflow lo publica
IMAGE_TAG=latest